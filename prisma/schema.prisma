generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shopify Store (one per installed merchant) ─────────────────
model Store {
  id              String   @id @default(cuid())
  shopDomain      String   @unique // e.g. "my-store.myshopify.com"
  shopName        String?
  accessToken     String   // Shopify OAuth access token (encrypted at rest)
  scopes          String   // granted scopes
  isActive        Boolean  @default(true)
  installedAt     DateTime @default(now())
  uninstalledAt   DateTime?

  // Relations
  settings        StoreSettings?
  orders          Order[]
  shipments       Shipment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Store Settings (OMS credentials + shipper info) ────────────
model StoreSettings {
  id              String   @id @default(cuid())
  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // OMS (EccangTMS) credentials
  omsApiToken     String?  // user's own EccangTMS API token
  omsBaseUrl      String   @default("https://api.saas.eccangtms.com")

  // Shipper (sender) info — filled by merchant
  shipperName         String?
  shipperCompanyName  String?
  shipperCountryCode  String   @default("US")
  shipperState        String?
  shipperCity         String?
  shipperAddress1     String?
  shipperAddress2     String?
  shipperPostCode     String?
  shipperPhone        String?
  shipperEmail        String?

  // Default package dimensions
  defaultWeightLbs    Float?
  defaultLengthIn     Float?
  defaultWidthIn      Float?
  defaultHeightIn     Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Order (synced from Shopify, simplified) ────────────────────
model Order {
  id                  String   @id @default(cuid())
  storeId             String
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  shopifyOrderId      String   @unique
  shopifyOrderNumber  String?
  shopifyStatus       String?
  customerName        String?
  customerEmail       String?
  shippingAddress     Json?
  totalPrice          Decimal? @db.Decimal(10, 2)
  currency            String   @default("USD")

  // Label status
  labelStatus         String   @default("NONE") // NONE | CREATED | SYNCED

  // Relations
  shipments           Shipment[]

  shopifyCreatedAt    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([storeId])
  @@index([labelStatus])
}

// ─── Shipment (label / tracking record) ─────────────────────────
model Shipment {
  id                  String   @id @default(cuid())
  storeId             String
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // OMS fields
  omsOrderNo          String?  // EccangTMS order number
  omsServerNo         String?  // EccangTMS server number (tracking)
  productCode         String?  // shipping product used
  productName         String?

  // Tracking
  trackingNumber      String?
  carrier             String?
  status              String   @default("pending") // pending | label_created | shipped | delivered | exception
  shippingCost        Decimal? @db.Decimal(10, 2)

  // Shopify sync
  shopifyFulfillmentId String?
  syncedToShopify     Boolean  @default(false)

  // Raw API response for debugging
  rawResponse         Json?

  shippedAt           DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([storeId])
  @@index([orderId])
}

// ─── Session (Shopify session storage for OAuth) ────────────────
model Session {
  id          String   @id
  shop        String
  state       String
  isOnline    Boolean  @default(false)
  scope       String?
  expires     DateTime?
  accessToken String?
  userId      BigInt?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop])
}
